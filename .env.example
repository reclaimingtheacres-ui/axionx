# AxionX Environment Configuration
# Copy this file to .env and fill in the values.
# Never commit real credentials to version control.

# ── Core ─────────────────────────────────────────────────────────────────────
FLASK_SECRET_KEY=change-me-to-a-random-secret

# ── Email / SMTP ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your-smtp-password

# ── Azure Blob Storage ────────────────────────────────────────────────────────
AZURE_BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=https;...
AZURE_CONTAINER_NAME=axionx-attachments

# ── APNs (iOS Push Notifications) ────────────────────────────────────────────
APNS_KEY_ID=XXXXXXXXXX
APNS_TEAM_ID=XXXXXXXXXX
APNS_BUNDLE_ID=com.yourcompany.axionx
APNS_KEY_PATH=/path/to/AuthKey_XXXXXXXXXX.p8

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Break-glass emergency access ─────────────────────────────────────────────
BREAK_GLASS_TOKEN=replace-with-a-strong-random-token


# ═══════════════════════════════════════════════════════════════════════════════
# DEMO ENVIRONMENT
# ═══════════════════════════════════════════════════════════════════════════════
#
# When AXIONX_DEMO_MODE=true the application runs in a fully isolated demo mode:
#   - Uses a separate SQLite database (axion_demo.db by default)
#   - All email sending, push notifications and Azure uploads are suppressed
#   - A visible banner is shown on every page: "DEMO ENVIRONMENT — NO LIVE DATA"
#   - All generated PDFs are watermarked "DEMO DOCUMENT — NOT FOR OPERATIONAL USE"
#   - /demo  routes are enabled (landing page, one-click role login, outbox, reset)
#
# Production (axion.db) is NEVER touched when demo mode is active.
#
# To activate demo mode:
#   1. Set AXIONX_DEMO_MODE=true
#   2. Set AXIONX_DB_PATH to the demo database path (default: ./axion_demo.db)
#      (AXIONX_DEMO_DB_PATH is accepted as an alias for the same purpose)
#   3. Seed the demo database:  python3 scripts/seed_demo.py --reset
#   4. Restart the application
#
# To deactivate demo mode:
#   1. Unset (or set to false) AXIONX_DEMO_MODE
#   2. Restart the application
#
# AXIONX_DEMO_MODE=true
# AXIONX_DB_PATH=./axion_demo.db
# AXIONX_DEMO_DB_PATH=./axion_demo.db  # alias — either name is accepted
