<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>

    <!-- App identity -->
    <key>CFBundleName</key>
    <string>AxionX</string>
    <key>CFBundleDisplayName</key>
    <string>AxionX</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleVersion</key>
    <string>$(CURRENT_PROJECT_VERSION)</string>
    <key>CFBundleShortVersionString</key>
    <string>$(MARKETING_VERSION)</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundlePackageType</key>
    <string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>

    <!-- SwiftUI App lifecycle — no UISceneDelegate class name required -->
    <key>UIApplicationSupportsMultipleScenes</key>
    <false/>

    <!-- Launch screen storyboard (shown before SwiftUI tree starts) -->
    <key>UILaunchStoryboardName</key>
    <string>LaunchScreen</string>

    <!-- iPhone only, portrait orientation -->
    <key>UIDeviceFamily</key>
    <array>
        <integer>1</integer>
    </array>
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
    </array>

    <!-- Status bar: white / light theme -->
    <key>UIStatusBarStyle</key>
    <string>UIStatusBarStyleDarkContent</string>
    <key>UIViewControllerBasedStatusBarAppearance</key>
    <true/>

    <!-- Appearance: force light mode for v1 -->
    <key>UIUserInterfaceStyle</key>
    <string>Light</string>

    <!-- App Transport Security -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <false/>
        <key>NSExceptionDomains</key>
        <dict>
            <!-- Allow HTTP on localhost for simulator dev builds only -->
            <key>localhost</key>
            <dict>
                <key>NSExceptionAllowsInsecureHTTPLoads</key>
                <true/>
                <key>NSIncludesSubdomains</key>
                <true/>
            </dict>
        </dict>
    </dict>

    <!-- Location permissions -->
    <key>NSLocationWhenInUseUsageDescription</key>
    <string>AxionX uses your location while the app is open to assist with nearby jobs, travel distance, and LPR dispatch decisions.</string>

    <key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
    <string>AxionX uses your location in the background when you set your field status to Available or Active Job. This lets the office see your last known position for dispatch decisions. No customer or file data is included.</string>

    <key>NSLocationAlwaysUsageDescription</key>
    <string>AxionX uses your location in the background to support low-power field availability tracking when you set your status to Available or Active Job.</string>

    <!-- Camera permission — required for live plate scanning -->
    <key>NSCameraUsageDescription</key>
    <string>AxionX requires camera access to scan vehicle registrations for live LPR lookups.</string>

    <!-- Background modes: location (significant-change + active-job), fetch (BG sync) -->
    <key>UIBackgroundModes</key>
    <array>
        <string>location</string>
        <string>fetch</string>
        <string>processing</string>
    </array>

    <!-- Background task identifiers -->
    <key>BGTaskSchedulerPermittedIdentifiers</key>
    <array>
        <string>com.axionx.sync</string>
    </array>

    <!-- App icon -->
    <key>CFBundleIconName</key>
    <string>AppIcon</string>

</dict>
</plist>
